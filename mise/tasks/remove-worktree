#!/usr/bin/env bash
#MISE description="Remove a worktree from the current workspace"
#MISE quiet=true
#
#USAGE arg "<project>" help="The project worktree to remove"
#USAGE arg "[workspace]" help="The target workspace. Defaults to current workspace."
#USAGE flag "--delete-branch" help="Also delete the branch from the all-in-one repo"
#USAGE complete "project" run="mise run list-projects"
#USAGE complete "workspace" run="mise run list-workspaces"

set -euo pipefail

DEVENV="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
ALL_IN_ONE="$DEVENV/all-in-one"

PROJECT="$usage_project"
DELETE_BRANCH=false
[[ "${usage_delete_branch:-}" == "true" ]] && DELETE_BRANCH=true

# --- resolve workspace directory ---

if [[ -n "${usage_workspace:-}" ]]; then
  if [[ ! -d "$DEVENV/workspaces/$usage_workspace" ]]; then
    echo "Error: '$usage_workspace' is not a valid workspace name."
    exit 1
  fi
  WORKSPACE_DIR="$DEVENV/workspaces/$usage_workspace"
else
  workspace=$(basename "$MISE_ORIGINAL_CWD")
  if [[ "$MISE_ORIGINAL_CWD" != "$DEVENV/workspaces/$workspace" ]]; then
    echo "Error: this command must be run from within a workspace directory."
    exit 1
  fi
  WORKSPACE_DIR="$DEVENV/workspaces/$workspace"
fi

# --- validate ---

WORKTREE_DIR="$WORKSPACE_DIR/$PROJECT"
PROJECT_DIR="$ALL_IN_ONE/$PROJECT"

if [[ ! -d "$WORKTREE_DIR" ]]; then
  echo "Error: $WORKTREE_DIR does not exist."
  exit 1
fi

if [[ ! -d "$PROJECT_DIR/.git" ]]; then
  echo "Error: '$PROJECT' not found in all-in-one/"
  exit 1
fi

# --- capture branch before deletion ---

BRANCH=$(git -C "$WORKTREE_DIR" branch --show-current 2>/dev/null || echo "")

# --- run post-remove-worktree hooks ---

HOOK_DIR="$DEVENV/hooks/post-remove-worktree"
if [[ -d "$HOOK_DIR" ]]; then
  for hook in "$HOOK_DIR"/*; do
    [[ -x "$hook" ]] || continue
    echo "Running hook: $(basename "$hook")"
    if ! "$hook" "$PROJECT" "$WORKSPACE_DIR" "$WORKTREE_DIR"; then
      echo "Warning: hook '$(basename "$hook")' failed (exit $?), continuing."
    fi
  done
fi

# --- remove ---

rm -rf "$WORKTREE_DIR"
git -C "$PROJECT_DIR" worktree prune

echo "Removed worktree $WORKTREE_DIR"

# --- optionally delete the branch ---

if $DELETE_BRANCH; then
  if [[ -z "$BRANCH" ]]; then
    echo "Warning: could not determine branch name, skipping branch deletion."
  elif [[ "$BRANCH" == "main" ]]; then
    echo "Refusing to delete branch 'main'."
  else
    git -C "$PROJECT_DIR" branch -d "$BRANCH"
    echo "Deleted branch '$BRANCH' from all-in-one/$PROJECT"
  fi
elif [[ -n "$BRANCH" ]] && [[ "$BRANCH" != "main" ]]; then
  echo "Branch '$BRANCH' kept in all-in-one/$PROJECT (use --delete-branch to remove it)"
fi
