#!/usr/bin/env bash
# Add a git worktree from all-in-one/<project> into the current workspace.
# Run from within a workspace directory (under workspaces/).
#
# Usage: add-worktree <project> [--branch <name>]
#
# The default branch name is derived from the workspace directory name
# by stripping the leading date prefix (e.g. 20260219-fix-issue → fix-issue).

set -euo pipefail

DEVENV="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ALL_IN_ONE="$DEVENV/all-in-one"

# --- argument parsing ---

if [[ $# -lt 1 ]]; then
  echo "Usage: add-worktree <project> [--branch <name>]"
  echo ""
  echo "Available projects:"
  ls "$ALL_IN_ONE"
  exit 1
fi

PROJECT="$1"
shift

BRANCH_OVERRIDE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --branch|-b) BRANCH_OVERRIDE="$2"; shift 2 ;;
    *) echo "Unknown argument: $1"; exit 1 ;;
  esac
done

# --- validate project ---

PROJECT_DIR="$ALL_IN_ONE/$PROJECT"
if [[ ! -d "$PROJECT_DIR/.git" ]]; then
  echo "Error: '$PROJECT' not found in all-in-one/ (or not a git repo)"
  echo ""
  echo "Available projects:"
  ls "$ALL_IN_ONE"
  exit 1
fi

# --- determine target path ---

WORKSPACE_DIR="$PWD"
WORKTREE_DIR="$WORKSPACE_DIR/$PROJECT"

if [[ -d "$WORKTREE_DIR" ]]; then
  echo "Error: $WORKTREE_DIR already exists."
  exit 1
fi

# --- determine branch name ---

WORKSPACE_NAME=$(basename "$WORKSPACE_DIR")
if [[ -n "$BRANCH_OVERRIDE" ]]; then
  BRANCH="$BRANCH_OVERRIDE"
else
  # Strip leading date prefix YYYYMMDD- if present
  BRANCH=$(echo "$WORKSPACE_NAME" | sed 's/^[0-9]\{8\}-//')
fi

# --- create worktree ---

if git -C "$PROJECT_DIR" show-ref --quiet "refs/heads/$BRANCH"; then
  echo "Branch '$BRANCH' already exists in $PROJECT, checking it out..."
  git -C "$PROJECT_DIR" worktree add "$WORKTREE_DIR" "$BRANCH"
else
  echo "Creating branch '$BRANCH' in $PROJECT..."
  git -C "$PROJECT_DIR" worktree add "$WORKTREE_DIR" -b "$BRANCH"
fi

# --- initialize submodules if present ---

if [[ -f "$WORKTREE_DIR/.gitmodules" ]]; then
  echo "Initializing submodules..."
  git -C "$WORKTREE_DIR" submodule update --init --recursive --quiet
fi

echo ""
echo "Done. $PROJECT checked out at branch '$BRANCH'."

# --- run post-add-worktree hooks ---

HOOK_DIR="$DEVENV/hooks/post-add-worktree"
if [[ -d "$HOOK_DIR" ]]; then
  for hook in "$HOOK_DIR"/*; do
    [[ -x "$hook" ]] || continue
    echo "Running hook: $(basename "$hook")"
    if ! "$hook" "$PROJECT" "$WORKSPACE_DIR" "$WORKTREE_DIR"; then
      echo "Warning: hook '$(basename "$hook")' failed (exit $?), continuing."
    fi
  done
fi
