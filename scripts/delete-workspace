#!/usr/bin/env bash
# Delete a workspace, removing all its git worktrees and their branches.
#
# Usage: delete-workspace <workspace>
#
# Removes every git worktree found in the workspace, deletes the associated
# branches (unless the branch is 'main'), then removes the workspace directory.
# Prompts for confirmation before making any changes.

set -euo pipefail

DEVENV="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ALL_IN_ONE="$DEVENV/all-in-one"
WORKSPACES="$DEVENV/workspaces"

if [[ $# -lt 1 ]]; then
  echo "Usage: delete-workspace <workspace>"
  exit 1
fi

WORKSPACE_NAME="$1"
WORKSPACE_DIR="$WORKSPACES/$WORKSPACE_NAME"

if [[ ! -d "$WORKSPACE_DIR" ]]; then
  echo "Error: workspace '$WORKSPACE_NAME' does not exist."
  exit 1
fi

# --- discover worktrees ---
# A git worktree has a .git _file_ (not directory) pointing to the main repo.

declare -a WORKTREE_PROJECTS=()
declare -a WORKTREE_BRANCHES=()

for entry in "$WORKSPACE_DIR"/*/; do
  [[ -d "$entry" ]] || continue
  [[ -f "$entry/.git" ]] || continue  # worktrees have a .git file

  project=$(basename "$entry")
  branch=$(git -C "$entry" branch --show-current 2>/dev/null || echo "")
  WORKTREE_PROJECTS+=("$project")
  WORKTREE_BRANCHES+=("$branch")
done

# --- show what will be deleted ---

echo "Workspace: $WORKSPACE_NAME"
echo ""

if [[ ${#WORKTREE_PROJECTS[@]} -gt 0 ]]; then
  echo "The following worktrees will be removed:"
  for i in "${!WORKTREE_PROJECTS[@]}"; do
    project="${WORKTREE_PROJECTS[$i]}"
    branch="${WORKTREE_BRANCHES[$i]}"
    if [[ -n "$branch" && "$branch" != "main" ]]; then
      echo "  - $project (branch '$branch' will be deleted)"
    elif [[ "$branch" == "main" ]]; then
      echo "  - $project (on 'main', branch will not be deleted)"
    else
      echo "  - $project"
    fi
  done
  echo ""
fi

echo "The workspace directory will be deleted:"
echo "  $WORKSPACE_DIR"
echo ""

read -p "Are you sure? (y/n) " CONFIRM
if [[ "$CONFIRM" != "y" ]]; then
  echo "Aborted."
  exit 0
fi

# --- remove worktrees ---

for i in "${!WORKTREE_PROJECTS[@]}"; do
  project="${WORKTREE_PROJECTS[$i]}"
  branch="${WORKTREE_BRANCHES[$i]}"
  project_dir="$ALL_IN_ONE/$project"
  worktree_dir="$WORKSPACE_DIR/$project"

  echo ""
  echo "Removing worktree: $project"

  rm -rf "$worktree_dir"

  if [[ -d "$project_dir/.git" ]]; then
    git -C "$project_dir" worktree prune
  fi

  if [[ -n "$branch" && "$branch" != "main" && -d "$project_dir/.git" ]]; then
    if git -C "$project_dir" branch -d "$branch" 2>/dev/null; then
      echo "  Deleted branch '$branch' from all-in-one/$project"
    else
      echo "  Warning: could not delete branch '$branch' from all-in-one/$project (may have unmerged changes)"
      echo "  You can force-delete it with: git -C all-in-one/$project branch -D $branch"
    fi
  fi
done

# --- remove workspace directory ---

echo ""
rm -rf "$WORKSPACE_DIR"
echo "Deleted workspace: $WORKSPACE_NAME"
